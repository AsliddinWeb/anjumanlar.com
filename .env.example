# ============================================================
# Anjumanlar.com — environment variables
# Copy to .env and fill in real values. NEVER commit .env.
# ============================================================

# ----- General -----
PROJECT_NAME=anjumanlar
ENVIRONMENT=development          # development | staging | production
TZ=Asia/Tashkent

# ----- Port layout (8300+) -----
# Internal container ports are standard; only host ports are remapped.
POSTGRES_PORT=8300
REDIS_PORT=8301
MINIO_API_PORT=8302
MINIO_CONSOLE_PORT=8303
MEILISEARCH_PORT=8304
MAILHOG_SMTP_PORT=8305
MAILHOG_UI_PORT=8306
BACKEND_PORT=8307
FRONTEND_PORT=8308
NGINX_HTTP_PORT=8309
FLOWER_PORT=8310

# ----- PostgreSQL -----
POSTGRES_USER=anjumanlar
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=anjumanlar
# In code use the container hostname; from host machine swap "postgres" → "localhost:8300"
DATABASE_URL=postgresql+asyncpg://anjumanlar:change-me-strong-password@postgres:5432/anjumanlar
DATABASE_URL_SYNC=postgresql://anjumanlar:change-me-strong-password@postgres:5432/anjumanlar

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- MinIO -----
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=http://localhost:8302
MINIO_SECURE=false
MINIO_BUCKET_BOOKS=books
MINIO_BUCKET_BOOKS_WM=books-watermarked
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_DEMOS=demos
MINIO_BUCKET_BLOG=blog

# ----- Meilisearch -----
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-32-chars-minimum-secret-key

# ----- JWT / Auth -----
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Email (dev: MailHog, prod: Brevo / Resend / SES) -----
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
EMAIL_FROM=noreply@anjumanlar.com
EMAIL_FROM_NAME=Anjumanlar.com

# ----- Payme.uz -----
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_ENDPOINT=https://checkout.test.paycom.uz/api    # test / sandbox
PAYME_CHECKOUT_URL=https://checkout.test.paycom.uz

# ----- Frontend (Nuxt) -----
NUXT_PUBLIC_API_BASE=http://localhost:8307/api/v1
NUXT_PUBLIC_SITE_URL=http://localhost:8308
NUXT_PUBLIC_SITE_NAME=Anjumanlar.com
NUXT_PUBLIC_DEFAULT_LOCALE=uz

# ----- CORS -----
CORS_ORIGINS=http://localhost:8308,http://127.0.0.1:8308

# ----- Sentry (optional) -----
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ----- File upload limits -----
MAX_BOOK_FILE_MB=100
MAX_DEMO_FILE_MB=20
MAX_COVER_FILE_MB=5
MAX_AVATAR_FILE_MB=2
