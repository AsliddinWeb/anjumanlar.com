# ============================================================
# Anjumanlar.com — PRODUCTION environment template
# Copy to ``.env`` on the server. NEVER commit the real file.
#
# Replace every "change-me-..." value before launching.
# ============================================================

# ----- General -----
PROJECT_NAME=anjumanlar
ENVIRONMENT=production
TZ=Asia/Tashkent

# ----- Port layout (host-side; only nginx 80/443 face the public NIC) -----
# Internal services bind to 127.0.0.1:<port> so the host can reach them
# without exposing to 0.0.0.0.
POSTGRES_PORT=8300
REDIS_PORT=8301
MINIO_API_PORT=8302
MINIO_CONSOLE_PORT=8303
MEILISEARCH_PORT=8304
BACKEND_PORT=8307
FRONTEND_PORT=8308
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# ----- PostgreSQL -----
POSTGRES_USER=anjumanlar
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=anjumanlar
DATABASE_URL=postgresql+asyncpg://anjumanlar:change-me-strong-postgres-password@postgres:5432/anjumanlar
DATABASE_URL_SYNC=postgresql://anjumanlar:change-me-strong-postgres-password@postgres:5432/anjumanlar

# ----- Redis -----
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ----- MinIO -----
# These two land on the *internal* docker hostname; the public endpoint
# is the URL the browser hits (presigned download URLs embed it).
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_ENDPOINT=minio:9000
# files.anjumanlar.com — alohida subdomen, MinIO presigned URL uchun.
# DNS: A record files.anjumanlar.com → server IP.
# Sertifikat: certonly chaqirig'iga -d files.anjumanlar.com qo'shing.
MINIO_PUBLIC_ENDPOINT=https://files.anjumanlar.com
MINIO_SECURE=false
MINIO_BUCKET_BOOKS=books
MINIO_BUCKET_BOOKS_WM=books-watermarked
MINIO_BUCKET_COVERS=covers
MINIO_BUCKET_AVATARS=avatars
MINIO_BUCKET_DEMOS=demos
MINIO_BUCKET_BLOG=blog

# ----- Meilisearch -----
MEILISEARCH_URL=http://meilisearch:7700
MEILISEARCH_MASTER_KEY=change-me-32-chars-minimum-meili-master-key

# ----- JWT / Auth -----
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- Email (production SMTP — Brevo / Resend / Mailgun / etc.) -----
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-smtp-user@example.com
SMTP_PASSWORD=change-me-smtp-password
SMTP_TLS=true
EMAIL_FROM=noreply@anjumanlar.com
EMAIL_FROM_NAME=Anjumanlar.com

# ----- Payme (leave blank until merchant credentials arrive) -----
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=
PAYME_ENDPOINT=https://checkout.paycom.uz/api
PAYME_CHECKOUT_URL=https://checkout.paycom.uz

# ----- Frontend (Nuxt) -----
# Browser-side URL (what visitors see).
NUXT_PUBLIC_API_BASE=https://anjumanlar.com/api/v1
# Server-side URL — Nuxt SSR talks to backend on the docker network.
NUXT_API_BASE_INTERNAL=http://backend:8000/api/v1
NUXT_PUBLIC_SITE_URL=https://anjumanlar.com
NUXT_PUBLIC_SITE_NAME=Anjumanlar.com
NUXT_PUBLIC_DEFAULT_LOCALE=uz
# Backend uses this to build absolute links in emails + presigned URLs.
FRONTEND_URL=https://anjumanlar.com

# ----- CORS -----
CORS_ORIGINS=https://anjumanlar.com,https://www.anjumanlar.com

# ----- Sentry (optional, but recommended for production) -----
# Backend (Python SDK). Leave blank to disable.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
# Frontend (browser SDK). Usually a separate project on Sentry side
# so frontend + backend error volumes can be billed separately.
NUXT_PUBLIC_SENTRY_DSN=
NUXT_PUBLIC_SENTRY_ENVIRONMENT=production

# ----- File upload limits -----
MAX_BOOK_FILE_MB=100
MAX_DEMO_FILE_MB=20
MAX_COVER_FILE_MB=5
MAX_AVATAR_FILE_MB=2
